{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moltbot-sandbox",
  "main": "src/index.ts",
  "compatibility_date": "2026-03-26",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": "./dist/client",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": true
  },
  "vars": {
    "PUBLIC_URL": "https://miracle.hardie.org",
    "NODE_ENV": "production",
    "HOST": "0.0.0.0",
    "PORT": "18789"
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["Sandbox"]
    }
  ],
  "durable_objects": {
    "bindings": [
      {
        "name": "Sandbox",
        "class_name": "Sandbox"
      }
    ]
  },
  "containers": [
    {
      "class_name": "Sandbox",
      "image": "./Dockerfile",
      "instance_type": "standard-1",
      "max_instances": 1
    }
  ],
  "kv_namespaces": [
    { "binding": "STATE", "id": "a1fd4c6e172c42bdbd1eac692345149d" },
    { "binding": "KV", "id": "a1fd4c6e172c42bdbd1eac692345149d" }
  ],
  "r2_buckets": [
    { "binding": "MOLTBOT_BUCKET", "bucket_name": "openclaw-memory" },
    { "binding": "MEMORY_BUCKET", "bucket_name": "openclaw-memory" }
  ],
  "browser": {
    "binding": "BROWSER"
  }
}
